---
import ComicLayout from "../../layouts/comicLayout.astro";
---

<ComicLayout title="Lindwyrm">
  <script defer>
    let pg = Number(findGetParameter("pg")); //make "pg" mean the current page number (this line doesnt work unless I put it here, if you're inexperienced with js dont worry about it)

    // COMIC PAGE SETTINGS
    const folder = "../../../public/comics/hitd"; //directory of the folder where you keep all the comics
    const image = "pg"; //what you'll name all your comic pages
    const ext = "webp"; //file extension of your comic pages

    //REALLY IMPORTANT ONES
    const maxpg = 7; //the current number of pages your comic has in total. this DOESNT necessarily mean number of IMAGE FILES as it doesn't count pages split into multiple files.
    //YOU MUST UPDATE THIS NUMBER EVERY TIME YOU ADD A NEW PAGE or else it wont display the most recent page

    if (pg == 0) {
      pg = 1;
    } //display MOST RECENT COMIC when the webpage is loaded. if you want to instead have the FIRST COMIC displayed first, change maxpg to 1.

    const pgData = [
      {
        pgNum: 1, //what page number it is
        altText: "",
      },
      {
        pgNum: 2,
        altText: "",
      },
      {
        pgNum: 3,
        altText: "",
      },
      {
        pgNum: 4,
        altText: "",
      },
      {
        pgNum: 5,
        altText: "",
      },
      {
        pgNum: 6,
        altText: "",
      },
      {
        pgNum: 7,
        altText: "",
      },
    ];

    function findGetParameter(parameterName) {
      //function used to write a parameter to append to the url, to give each comic page its own unique url
      let result = null,
        tmp = [];
      let items = location.search.substr(1).split("&");
      for (let index = 0; index < items.length; index++) {
        tmp = items[index].split("=");
        if (tmp[0] === parameterName) result = decodeURIComponent(tmp[1]);
      }
      return result;
    }
  </script>
</ComicLayout>
