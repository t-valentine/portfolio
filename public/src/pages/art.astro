---
import SinglecolumnLayout from "../layouts/singlecolumnLayout.astro";
---

<style>
  .gallery {
    padding-top: 1em;
    columns: auto 3;
    column-gap: 5px;
    text-align: center;
  }

  figure {
    display: inline-block;
    margin: 0;
    margin-bottom: 15px;
  }

  .gallery img {
    width: 100%;
    border: 1px solid black;
    background-color: white;
  }
  h2,
  h3 {
    padding: 5px;
    border-radius: 8px;
  }
  h2 {
    background-color: #ca9ee6;
  }
  h3 {
    background-color: #f5c2e7;
  }

  @media screen and (max-width: 850px) {
    .gallery {
      columns: 1;
    }
  }
</style>
<SinglecolumnLayout title="Art">
  <div>
    <p>
      <span style="margin-right: 15px; font-weight: 800;"
        >Table of Contents...</span
      >
      <a href="#general">general</a> | <a href="#ttrpg">TTRPG</a> | <a
        href="#fanart">Fanart</a
      > | <a href="#projects">projects</a>
    </p>
  </div>
  <h2 id="general">General</h2>
  <div class="gallery">
    <figure>
      <img
        src="../../public/illustrations/fairies.webp"
